# ============================================================
# points-mall-shop — Environment Variables Reference
# Copy this file to .env and fill in real values.
# NEVER commit .env with real secrets to Git.
#
# Laravel env profiles: set APP_ENV to local | testing | production.
# Laravel reads this single .env file; use CI/CD to inject environment-specific values.
# ============================================================

# ── Application ─────────────────────────────────────────────
APP_NAME=PointsMallShop
# local | testing | production
APP_ENV=local
# Required: generate with `php artisan key:generate`
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8081
APP_PORT=8081

# ── Logging ─────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── PostgreSQL (Neon) ───────────────────────────────────────
# Option A — full URL (recommended for Neon, supports SSL automatically):
# DB_URL=postgresql://<username>:<password>@<neon-pooler-host>/dbname?sslmode=require
#
# Option B — individual vars (set PGSSLMODE for SSL):
DB_CONNECTION=
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
PGSSLMODE=require

# ── Cache ───────────────────────────────────────────────────
# file | redis | array (use redis in production)
CACHE_DRIVER=file
CACHE_PREFIX=points_shop

# ── Session ─────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Queue ───────────────────────────────────────────────────
# sync | redis | rabbitmq (use redis or rabbitmq in production)
QUEUE_CONNECTION=sync

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

# ── Amazon Product Advertising API (Required for product sync) ──
AMAZON_PA_ACCESS_KEY=
AMAZON_PA_SECRET_KEY=
AMAZON_PA_PARTNER_TAG=
AMAZON_PA_REGION=
# Points per USD conversion rate (e.g. 10 means $1 = 10 points)
AMAZON_POINTS_CONVERSION_RATE=10

# ── Internal Service URLs ────────────────────────────────────
BFF_INTERNAL_URL=http://localhost:4000
THIRDPARTY_SERVICE_URL=http://localhost:8084
